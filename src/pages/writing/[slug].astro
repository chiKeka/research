---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('writing');
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Base title={post.data.title} description={post.data.summary}>
  <article class="measure">
    <p class="eyebrow">{post.data.platform} · {post.data.date}</p>
    <h1>{post.data.title}</h1>
    {post.data.external_url && (
      <p class="small muted">
        Originally published on {post.data.platform} —
        <a href={post.data.external_url}>read the original →</a>
      </p>
    )}
    <hr />
    <Content />
    {post.data.external_url && (
      <>
        <hr />
        <p class="small muted">
          First ran on {post.data.platform}:
          <a href={post.data.external_url}>{post.data.external_url}</a>
        </p>
      </>
    )}
    <p><a href="/writing">← All writing</a></p>
  </article>
</Base>
