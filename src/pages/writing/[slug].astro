---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('writing');
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const site = Astro.site ?? new URL('https://research-azure-omega.vercel.app');
const canonical = new URL(`/writing/${post.id}`, site).href;
const articleLd = {
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.summary,
  datePublished: post.data.date,
  ...(post.data.updated ? { dateModified: post.data.updated } : {}),
  author: { '@id': `${site.origin}/#person` },
  publisher: { '@id': `${site.origin}/#person` },
  mainEntityOfPage: canonical,
  url: canonical,
  image: new URL('/og.png', site).href,
};
---

<Base
  title={post.data.title}
  description={post.data.summary}
  ogType="article"
  publishedTime={post.data.date}
  modifiedTime={post.data.updated}
  jsonLd={articleLd}
>
  <article class="measure">
    <p class="eyebrow">{post.data.platform} · {post.data.date}</p>
    <h1>{post.data.title}</h1>
    {post.data.external_url && (
      <p class="small muted">
        Originally published on {post.data.platform} —
        <a href={post.data.external_url}>read the original →</a>
      </p>
    )}
    <hr />
    <Content />

    {post.data.sources && post.data.sources.length > 0 && (
      <>
        <hr />
        <h2>Sources</h2>
        <ol class="sources small">
          {post.data.sources.map((s) => (
            <li><a href={s.href}>{s.label}</a></li>
          ))}
        </ol>
      </>
    )}

    {post.data.external_url && (
      <>
        <hr />
        <p class="small muted">
          First ran on {post.data.platform}:
          <a href={post.data.external_url}>{post.data.external_url}</a>
        </p>
      </>
    )}
    <p><a href="/writing">← All writing</a></p>
  </article>
</Base>
