---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('writing');
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const platformLabel = (p) => (p === 'x' ? 'X' : p === 'linkedin' ? 'LinkedIn' : (p || 'Web'));

const site = Astro.site ?? new URL('https://research-azure-omega.vercel.app');
const canonical = new URL(`/writing/${post.id}`, site).href;
const articleLd = {
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.summary,
  datePublished: post.data.date,
  ...(post.data.updated ? { dateModified: post.data.updated } : {}),
  author: { '@id': `${site.origin}/#person` },
  publisher: { '@id': `${site.origin}/#person` },
  mainEntityOfPage: canonical,
  url: canonical,
  image: new URL('/og.png', site).href,
};
---

<Base title={post.data.title} description={post.data.summary} ogType="article"
  publishedTime={post.data.date} modifiedTime={post.data.updated} jsonLd={articleLd}
  tagline="● An essay, in the open">
  <div class="wrap">
    <article class="art">
      <div class="art-head">
        <div class="src"><span>{platformLabel(post.data.platform)} · {post.data.date}</span></div>
        <h1>{post.data.title}</h1>
        {post.data.external_url && (
          <p class="mono" style="color:var(--dim);margin-top:14px">Originally published on {platformLabel(post.data.platform)} — <a class="accent" href={post.data.external_url}>read the original →</a></p>
        )}
      </div>
      <div class="prose">
        <Content />
        {post.data.sources && post.data.sources.length > 0 && (
          <>
            <hr />
            <h2>Sources</h2>
            <ol>{post.data.sources.map((s) => (<li><a href={s.href}>{s.label}</a></li>))}</ol>
          </>
        )}
        {post.data.external_url && (
          <>
            <hr />
            <p class="mono" style="font-size:13px">First ran on {platformLabel(post.data.platform)}: <a href={post.data.external_url}>{post.data.external_url}</a></p>
          </>
        )}
      </div>
      <p style="margin-top:30px"><a class="btn line" href="/writing">← All writing</a></p>
    </article>
  </div>
</Base>

<style>
  .art{max-width:760px;margin:0 auto;padding:48px 0 64px}
  .art-head{border-bottom:2px solid var(--ink);padding-bottom:26px;margin-bottom:30px}
  .art-head .src{font-family:var(--mono);font-size:11px;text-transform:uppercase;letter-spacing:.14em;color:var(--accent);margin-bottom:16px}
  .art-head h1{font-family:var(--serif);font-size:clamp(32px,4.4vw,56px);line-height:1.02;letter-spacing:-.015em}
</style>
