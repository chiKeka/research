---
import Base from '../layouts/Base.astro';
import SystemsMap from '../components/SystemsMap.astro';

const entries = [
  {
    id: 'infrastructure', no: 'No. 01 — Infrastructure', swatch: 'c-infra', meta: ['Active line', '9 predictions open', '4 frameworks'],
    name: 'AI Infrastructure & Sovereign Compute',
    big: 'Where AI meets the physical layer — <b>energy, capital, and policy</b>. What it takes for a region like Alberta or a continent like Africa to own compute rather than rent it.',
    body: 'The frontier is increasingly a question of who can site gigawatts, sign power agreements, and underwrite the capex — not who can write the model. That reframes AI strategy as an industrial and energy problem, and it changes who has leverage. Alberta has stranded gas and a grid; Africa has demand, demographics, and a financing gap. Both are case studies in the same question: rent, or own.',
    qs: ["What's the minimum viable stack for sovereign compute in a mid-size economy?", 'When does owning beat renting on a 10-year horizon — and for whom?', 'Which policy levers actually move private capex into compute?'],
    tags: ['energy', 'capex', 'policy', 'Alberta', 'Africa'],
  },
  {
    id: 'agents', no: 'No. 02 — Agents', swatch: 'c-agent', meta: ['Active line', '11 predictions open', '7 frameworks'],
    name: 'Agentic Systems',
    big: 'The orchestration and trust primitives that let agents do real work — <b>loop engineering</b>, and the missing pieces between a demo and a system you can depend on.',
    body: 'Most agent demos work once and never again. The gap between a clever loop and a dependable system is made of unglamorous primitives: verification, memory you can audit, escalation paths, and a way to know when the agent is wrong. I call the discipline of building those loops loop engineering — and I think it becomes a named job before 2028.',
    qs: ['What are the missing trust primitives between a demo and production?', 'Do agent frameworks converge on a shared trust layer — or fragment?', 'What does a dependable agentic loop actually guarantee?'],
    tags: ['orchestration', 'trust primitives', 'loop engineering', 'reliability'],
  },
  {
    id: 'governance', no: 'No. 03 — Governance', swatch: 'c-gov', meta: ['Active line', '8 predictions open', '6 frameworks'],
    name: 'Governance & Knowledge Gradients',
    big: 'Who controls capability, and how <b>knowledge gradients</b> form and close. Institutions, incentives, and the design layer that decides who AI actually serves.',
    body: 'A knowledge gradient is the gap between those who can shape a system and those who can only use it. AI both steepens and flattens these gradients, depending on who designs the interface. Governance, here, is less about regulation in the abstract and more about the concrete design-layer choices that route capability toward — or away from — the people it claims to serve.',
    qs: ['How do knowledge gradients form, and what closes them?', 'Which institutions are positioned to control frontier capability?', 'Where does the design layer decide who AI serves?'],
    tags: ['institutions', 'incentives', 'design layer', 'access'],
  },
  {
    id: 'epistemics', no: 'No. 04 — Epistemics', swatch: 'c-epi', meta: ['Active line', '9 predictions open', '7 frameworks'],
    name: 'Public Epistemics',
    big: 'Reasoning you can audit — predicting in public with <b>locked probabilities</b>, scoring calibration, and naming the frameworks so they can be argued with and retired.',
    body: 'This is the method made into a research line of its own. If the other three lines produce claims, this one is about how those claims are made checkable: every prediction registered with a probability and a falsifier, scored when reality lands, calibration tracked over time. The point isn\'t to be right; it\'s to be auditable — and to make being wrong cheap enough to admit.',
    qs: ['Can public calibration scoring change forecasting incentives?', "What's the right unit for a falsifiable claim about systems?", 'When should a named framework be retired rather than patched?'],
    tags: ['forecasting', 'calibration', 'falsifiers', 'the ledger'],
  },
];
---

<Base title="Research" tagline="● The research agenda"
  description="A systems research agenda: AI infrastructure, agentic systems, governance, and public epistemics.">
  <div class="wrap">
    <section class="agenda">
      <div class="copy">
        <div class="kicker mono accent" style="margin-bottom:16px">The agenda · four lines</div>
        <h1>Four lines into one <em>system.</em></h1>
        <p class="deck">The research isn't four topics — it's one system seen from four angles. Capability is the center; institutions, incentives, infrastructure and culture are the forces that decide where it lands. Drag the map to see how they pull on each other.</p>
        <div style="margin-top:24px;display:flex;gap:13px;flex-wrap:wrap">
          <a class="btn solid" href="/ledger">See predictions</a>
          <a class="btn line" href="/frameworks">The named frameworks</a>
        </div>
      </div>
      <div class="mapcol"><SystemsMap title="Capability ↔ forces" /></div>
    </section>

    {entries.map((e) => (
      <article class="entry" id={e.id}>
        <div class="side">
          <div class="no">{e.no}</div>
          <div class={`swatch ${e.swatch}`}></div>
          <div class="meta" set:html={e.meta.join('<br>')}></div>
        </div>
        <div>
          <h2>{e.name}</h2>
          <p class="big" set:html={e.big}></p>
          <p>{e.body}</p>
          <div class="qs">
            <div class="h">Open questions</div>
            <ul>{e.qs.map((q) => <li>{q}</li>)}</ul>
          </div>
          <div class="tags">{e.tags.map((t) => <span class="tag">{t}</span>)}</div>
          {e.id === 'epistemics' && (<p style="margin-top:22px"><a class="btn line" href="/ledger">Open the prediction ledger →</a></p>)}
        </div>
      </article>
    ))}
  </div>
</Base>

<style>
  .agenda{display:grid;grid-template-columns:1fr 1fr;gap:0;border-bottom:2px solid var(--ink)}
  .agenda .copy{padding:42px 44px 46px 0;border-right:1px solid var(--rule)}
  .agenda .copy h1{font-family:var(--serif);font-size:clamp(36px,5.2vw,72px);line-height:.97;letter-spacing:-.015em}
  .agenda .copy h1 em{font-style:italic;color:var(--accent)}
  .agenda .copy .deck{margin-top:22px;font-size:20px;line-height:1.55;color:var(--ink2);max-width:46ch}
  .agenda .mapcol{padding:24px 0 24px 40px;display:flex}
  .agenda .mapcol :global(.mapwrap){flex:1;min-height:380px}
  @media(max-width:880px){.agenda{grid-template-columns:1fr}.agenda .copy{border-right:none;padding:0 0 36px}.agenda .mapcol{padding:0 0 36px;border-top:1px solid var(--rule)}.agenda .mapcol :global(.mapwrap){height:340px;min-height:0}}
  .entry{padding:48px 0;border-bottom:1px solid var(--rule);display:grid;grid-template-columns:200px 1fr;gap:40px;scroll-margin-top:160px}
  .entry .no{font-family:var(--mono);font-size:12px;letter-spacing:.12em;color:var(--accent);text-transform:uppercase}
  .entry .swatch{width:100%;height:8px;margin-top:14px}
  .entry .meta{font-family:var(--mono);font-size:11px;color:var(--dim);text-transform:uppercase;letter-spacing:.06em;line-height:2;margin-top:18px}
  .entry h2{font-family:var(--serif);font-size:clamp(28px,3.6vw,44px);line-height:1.04;letter-spacing:-.01em;margin-bottom:16px}
  .entry .big{font-size:21px;line-height:1.6;color:var(--ink2);max-width:60ch;margin-bottom:18px}
  .entry .big :global(b){color:var(--ink);font-weight:500}
  .entry p{font-size:17px;line-height:1.65;color:var(--ink2);max-width:62ch;margin-bottom:14px}
  .entry .qs{margin-top:22px;border-top:1px solid var(--rule);padding-top:18px}
  .entry .qs .h{font-family:var(--mono);font-size:11px;text-transform:uppercase;letter-spacing:.12em;color:var(--dim);margin-bottom:12px}
  .entry .qs ul{list-style:none}
  .entry .qs li{font-family:var(--read);font-size:16px;color:var(--ink);padding:8px 0 8px 24px;position:relative;border-bottom:1px dashed var(--rule)}
  .entry .qs li:last-child{border-bottom:none}
  .entry .qs li::before{content:"→";position:absolute;left:0;color:var(--accent)}
  .entry .tags{display:flex;gap:8px;flex-wrap:wrap;margin-top:20px}
  @media(max-width:760px){.entry{grid-template-columns:1fr;gap:18px}}
  .c-infra{background:var(--ochre)}.c-agent{background:var(--accent2)}.c-gov{background:var(--slate)}.c-epi{background:var(--accent)}
</style>
