---
import Base from '../layouts/Base.astro';
---

<Base title="Not found" description="Page not found." tagline="● Off the record">
  <div class="wrap">
    <section class="page-intro" style="border-bottom:none">
      <div class="kicker">404</div>
      <h1>This page isn't <em>on the record.</em></h1>
      <p class="deck">The link is broken or the page moved. Everything here is built in the open — try one of these instead.</p>
      <div style="margin-top:26px;display:flex;gap:13px;flex-wrap:wrap">
        <a class="btn solid" href="/">Home</a>
        <a class="btn line" href="/research">Research</a>
        <a class="btn line" href="/ledger">Ledger</a>
        <a class="btn line" href="/writing">Writing</a>
      </div>
    </section>
  </div>
</Base>
