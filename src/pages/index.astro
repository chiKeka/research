---
import Base from '../layouts/Base.astro';
import SystemsMap from '../components/SystemsMap.astro';
import { getCollection } from 'astro:content';
import ledger from '../data/ledger.json';
import { classify, truncate } from '../lib/ledger-stats.mjs';

const claims = ledger.claims ?? [];
const { open, resolved } = classify(claims);
const liveCount = open.length + resolved.length;
const sample = open[0];
const sampleP = Math.round((sample?.confidence ?? 0) * 100);

const writing = (await getCollection('writing'))
  .filter((w) => w.data.published !== false)
  .sort((a, b) => (b.data.date || '').localeCompare(a.data.date || ''))
  .slice(0, 2);

const lines = [
  { no: 'No. 01 — Infrastructure', anchor: 'infrastructure', name: 'AI Infrastructure & Sovereign Compute', blurb: 'Where AI meets the physical layer — energy, capital, and policy. What it takes for a region like Alberta or a continent like Africa to own compute rather than rent it.' },
  { no: 'No. 02 — Agents', anchor: 'agents', name: 'Agentic Systems', blurb: 'The orchestration and trust primitives that let agents do real work — loop engineering, and the missing pieces between a demo and a system you can depend on.' },
  { no: 'No. 03 — Governance', anchor: 'governance', name: 'Governance & Knowledge Gradients', blurb: 'Who controls capability, and how knowledge gradients form and close. Institutions, incentives, and the design layer that decides who AI actually serves.' },
  { no: 'No. 04 — Epistemics', anchor: 'epistemics', name: 'Public Epistemics', blurb: 'Reasoning you can audit — predicting in public with locked probabilities, scoring calibration, and naming the frameworks so they can be argued with and retired.' },
];
const applied = [
  { t: 'Venture', n: 'Afrigent', p: 'An AI agent platform — orchestration and trust primitives put to work.' },
  { t: 'Strategy', n: 'Akinke', p: 'Sovereign-infrastructure strategy for compute ownership.' },
  { t: 'Education', n: 'Design-layer', p: 'Closing the knowledge gradient at the layer that decides who AI serves.' },
  { t: 'Open', n: 'The Ledger', p: 'Its own repo. Predictions, falsifiers, and scores — versioned in public.' },
];
const platformLabel = (p) => (p === 'x' ? 'X' : p === 'linkedin' ? 'LinkedIn' : (p || 'Web'));
---

<Base tagline="● Built in the open · predictions locked & scored">
  <div class="wrap">
    <section class="lead">
      <div class="lead-main">
        <div class="kicker">The systems desk — lead essay</div>
        <h1 class="headline">Where AI capability meets <em>institutions, incentives &amp; infrastructure.</em></h1>
        <div class="deck"><p class="drop">I study how technology, institutions, incentives, and culture interact — AI infrastructure, agentic systems, and governance, with an eye on Africa and Alberta. The work is done in public, the predictions are score-kept, and the frameworks are named so they can be argued with.</p></div>
        <div class="lead-cta">
          <a class="btn solid" href="/research">Read the research</a>
          <a class="btn line" href="/ledger">See the prediction ledger</a>
        </div>
        <div class="byline">By <b>Bruno Chikeka</b> — systems-oriented technologist</div>
      </div>
      <aside class="lead-side">
        <SystemsMap title="The system, mapped" />
      </aside>
    </section>

    <section class="blk">
      <div class="sec-rule"><h2>Research Lines</h2><div class="ln"></div><a class="more" href="/research">Read the agenda →</a></div>
      <div class="lines">
        {lines.map((l) => (
          <div class="line"><a href={`/research#${l.anchor}`}><div class="no">{l.no}</div><h3>{l.name}</h3><p>{l.blurb}</p></a></div>
        ))}
      </div>
    </section>

    <section class="blk">
      <div class="sec-rule"><h2>Method</h2><div class="ln"></div><a class="more" href="/ledger">Open the ledger →</a></div>
      <div class="method">
        <div class="body">
          <p class="pull">Analysis usually ends in a confident take that nobody can check later. This practice ends in a commitment you can.</p>
          <p>Every prediction is registered with a probability that <b>locks the moment it is stated</b> and a written test for what would prove it wrong — then it is scored when reality lands.</p>
          <p><b>Nothing is edited; nothing is quietly deleted.</b> The frameworks are named so they can be argued with — and, when they fail, retired in public.</p>
          <a class="btn line" href="/ledger" style="margin-top:6px">Browse all {liveCount} records</a>
        </div>
        {sample && (
          <a class="terminal barscope tlink" href={`/ledger/${sample.id}`}>
            <div class="thead"><span class="cdot r"></span><span class="cdot y"></span><span class="cdot g"></span><span class="fname">prediction.ledger — {sample.id}</span><span class="tlive"><span class="dot"></span>locked</span></div>
            <div class="tbody"><span class="c"># registered {(sample.registered_at || '').slice(0, 10)} · locked</span>
<span class="k">claim</span>: <span class="s">"{truncate(sample.claim, 74)}"</span>
<span class="k">resolves</span>: <span class="s">{sample.resolve_by}</span>
<span class="k">falsifier</span>: <span class="r">"{truncate(sample.update_test, 60)}"</span>
<div class="tbar"><span class="lab">probability</span><span class="track"><i style={`width:${sampleP}%`}></i></span><span class="pv">{sample.confidence.toFixed(2)}</span></div><span class="k">status</span>: <span class="g">OPEN</span>
<span class="c"># no edits. no deletes. scored on landing.</span></div>
          </a>
        )}
      </div>
    </section>

    <section class="blk">
      <div class="sec-rule"><h2>Writing</h2><div class="ln"></div><a class="more" href="/writing">All writing →</a></div>
      <div class="wgrid">
        {writing.map((w) => (
          <a class="wcol" href={`/writing/${w.id}`}><div class="src"><span>{platformLabel(w.data.platform)}</span><span>{w.data.date}</span></div><h3>{w.data.title}</h3><p>{w.data.summary}</p><span class="read">Read the essay →</span></a>
        ))}
      </div>
    </section>

    <section class="blk">
      <div class="sec-rule"><h2>Applied Work</h2><div class="ln"></div><a class="more" href="/projects">All projects →</a></div>
      <div class="applied">
        {applied.map((a) => (
          <div class="ap"><span class="t">{a.t}</span><div class="n">{a.n}</div><p>{a.p}</p></div>
        ))}
      </div>
    </section>
  </div>
</Base>

<style>
  .lead{display:grid;grid-template-columns:1fr 1fr;gap:0;border-bottom:2px solid var(--ink)}
  .lead-main{padding:42px 44px 46px 0;border-right:1px solid var(--rule)}
  .lead .kicker{font-family:var(--mono);font-size:12px;letter-spacing:.2em;text-transform:uppercase;color:var(--accent);margin-bottom:18px}
  h1.headline{font-family:var(--serif);font-size:clamp(34px,5vw,68px);line-height:.99;letter-spacing:-.015em;max-width:14ch}
  h1.headline em{font-style:italic;color:var(--accent)}
  .deck{margin-top:24px;font-size:20px;line-height:1.55;max-width:46ch;color:var(--ink2)}
  .deck .drop::first-letter{font-family:var(--serif);font-size:3em;float:left;line-height:.78;padding:6px 10px 0 0;color:var(--accent)}
  .lead-cta{display:flex;gap:14px;margin-top:26px;flex-wrap:wrap}
  .byline{margin-top:26px;font-family:var(--mono);font-size:12px;text-transform:uppercase;letter-spacing:.1em;color:var(--dim);border-top:1px solid var(--rule);padding-top:16px}
  .byline b{color:var(--ink)}
  .lead-side{padding:24px 0 24px 40px;display:flex;flex-direction:column}
  .lead-side :global(.mapwrap){flex:1;min-height:360px}
  @media(max-width:880px){
    .lead{grid-template-columns:1fr}
    .lead-main{border-right:none;padding:38px 0}
    .lead-side{padding:0 0 36px;border-top:1px solid var(--rule)}
    .lead-side :global(.mapwrap){min-height:320px;height:340px}
  }
  .lines{columns:2;column-gap:48px;column-rule:1px solid var(--rule)}
  .line{break-inside:avoid;padding-bottom:28px;margin-bottom:28px;border-bottom:1px solid var(--rule)}
  .line:last-child{border-bottom:none}
  .line .no{font-family:var(--mono);font-size:12px;color:var(--accent);letter-spacing:.1em}
  .line h3{font-family:var(--serif);font-size:25px;margin:8px 0 10px;line-height:1.1}
  .line a:hover h3{color:var(--accent)}
  .line p{font-size:16px;color:var(--ink2);line-height:1.55}
  @media(max-width:760px){.lines{columns:1}}
  .method{display:grid;grid-template-columns:1.1fr .9fr;gap:48px;align-items:center}
  .method .body{font-size:19px;line-height:1.7;color:var(--ink2)}
  .method .pull{font-family:var(--serif);font-size:28px;line-height:1.18;color:var(--ink);border-left:4px solid var(--accent);padding-left:22px;margin:0 0 24px}
  .method .body p{margin-bottom:16px}.method .body b{color:var(--ink);font-weight:500}
  @media(max-width:880px){.method{grid-template-columns:1fr;gap:30px}}
  .tlink{text-decoration:none;display:block}
  .wgrid{display:grid;grid-template-columns:1fr 1fr;border:1.5px solid var(--ink)}
  .wcol{padding:30px 28px}
  .wcol:first-child{border-right:1px solid var(--rule)}
  .wcol .src{font-family:var(--mono);font-size:11px;text-transform:uppercase;letter-spacing:.12em;color:var(--accent);display:flex;justify-content:space-between;border-bottom:1px solid var(--rule);padding-bottom:10px;margin-bottom:16px}
  .wcol h3{font-family:var(--serif);font-size:26px;line-height:1.12;margin-bottom:14px}
  .wcol:hover h3{color:var(--accent)}
  .wcol p{font-size:16px;color:var(--ink2);line-height:1.55}
  .wcol .read{font-family:var(--mono);font-size:11px;text-transform:uppercase;letter-spacing:.1em;color:var(--ink);margin-top:16px;display:inline-block;border-bottom:1.5px solid var(--accent)}
  @media(max-width:760px){.wgrid{grid-template-columns:1fr}.wcol:first-child{border-right:none;border-bottom:1px solid var(--rule)}}
  .applied{display:grid;grid-template-columns:repeat(4,1fr);border:1.5px solid var(--ink)}
  .ap{padding:26px 22px;border-right:1px solid var(--rule)}
  .ap:last-child{border-right:none}
  .ap .n{font-family:var(--serif);font-size:22px;margin-bottom:8px}
  .ap p{font-size:14px;color:var(--ink2);line-height:1.5}
  .ap .t{font-family:var(--mono);font-size:10px;text-transform:uppercase;letter-spacing:.1em;color:var(--accent);display:block;margin-bottom:12px}
  @media(max-width:760px){.applied{grid-template-columns:1fr 1fr}.ap{border-bottom:1px solid var(--rule)}.ap:nth-child(odd){border-right:1px solid var(--rule)}.ap:nth-child(even){border-right:none}}
</style>
