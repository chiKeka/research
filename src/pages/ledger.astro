---
import Base from '../layouts/Base.astro';
import ledger from '../data/ledger.json';
import frameworks from '../data/frameworks.json';
import {
  classify, isInvalid, isWithdrawn, outcomeBinary, brierScore, scoredClaims, truncate,
} from '../lib/ledger-stats.mjs';

const claims = ledger.claims ?? [];
const { open, resolved, invalid, withdrawn } = classify(claims);
const source = ledger.source ?? null;

// Calibration (real numbers).
const brier = brierScore(claims);
const scored = scoredClaims(claims);
const hits = scored.filter((c) => outcomeBinary(c) === 1).length;
const meanConf = scored.length ? scored.reduce((a, c) => a + c.confidence, 0) / scored.length : null;

// Records: newest first, with a render-ready status.
const statusOf = (c) => {
  if (isInvalid(c)) return 'invalid';
  if (isWithdrawn(c)) return 'withdrawn';
  if (c.status === 'resolved') return outcomeBinary(c) === 0 ? 'miss' : 'hit';
  return 'open';
};
const label = { open: 'OPEN', hit: 'RESOLVED · HIT', miss: 'RESOLVED · MISS', invalid: 'INVALIDATED', withdrawn: 'WITHDRAWN' };
const recs = [...claims]
  .sort((a, b) => (b.registered_at || b.date || '').localeCompare(a.registered_at || a.date || ''))
  .map((c) => ({
    c,
    st: statusOf(c),
    p: Math.round((c.confidence ?? 0) * 100),
    date: (c.registered_at || c.date || '').slice(0, 10),
    tier: c.tier || 'claim',
  }));
---

<Base title="Prediction Ledger" tagline="● Predictions locked & scored in public"
  description="A public, score-kept record of falsifiable predictions — locked probabilities, immutable, Brier-scored.">
  <div class="wrap">
    <section class="ledhero">
      <div class="copy">
        <div class="kicker mono accent" style="margin-bottom:16px">The prediction ledger</div>
        <h1>Score, kept in <em>public.</em></h1>
        <div class="deck">Analysis usually ends in a confident take that nobody can check later. <b>This ends in a commitment you can.</b> Every claim locks a probability and a written falsifier the moment it's stated, then it's scored when reality lands.</div>
        <p style="margin-top:20px;font-family:var(--mono);font-size:13px;color:var(--dim);letter-spacing:.04em">// nothing is edited. nothing is quietly deleted.</p>
        {source && (
          <p style="margin-top:14px;font-family:var(--mono);font-size:11px;color:var(--dim)">rendered from <a class="accent" href={source.url}>chiKeka/ledger@{source.commit_short}</a></p>
        )}
      </div>
      <aside class="board">
        <div class="side-h"><span>The Scoreboard</span><span>{ledger.updated?.slice(0, 4)}</span></div>
        <div class="scoreboard">
          <div class="sb"><span class="num a">{open.length}</span><span class="lab">Open predictions</span></div>
          <div class="sb"><span class="num">{resolved.length}</span><span class="lab">Resolved &amp; scored</span></div>
          <div class="sb"><span class="num">{invalid.length}</span><span class="lab">Invalidated</span></div>
          <div class="sb"><span class="num">{frameworks.length}</span><span class="lab">Named frameworks</span></div>
        </div>
      </aside>
    </section>

    <section class="blk">
      <div class="sec-rule"><h2>Calibration</h2><div class="ln"></div><a class="more" href="/methodology">how scoring works →</a></div>
      <div class="calib">
        <div class="cell"><div class="l">Brier score · twin</div><div class="v"><b>{brier.mean === null ? '—' : brier.mean.toFixed(3)}</b></div><div class="note">Mean of (probability − outcome)². Lower is better. Across the {brier.n} resolved claims.</div></div>
        <div class="cell"><div class="l">Hit rate vs. stated</div><div class="v">{hits} / {scored.length}</div><div class="note">Scored against the locked probability. Invalidated claims never score.</div></div>
        <div class="cell"><div class="l">Mean confidence</div><div class="v">{meanConf === null ? '—' : meanConf.toFixed(2)}</div><div class="note">Across resolved claims. Early sample — read as directional.</div></div>
      </div>
    </section>

    <section class="blk" style="border-bottom:none">
      <div class="sec-rule"><h2>Records</h2><div class="ln"></div><span class="more">{claims.length} records · newest first</span></div>
      <div class="filters">
        <button class="fbtn on" data-f="all">All</button>
        <button class="fbtn" data-f="open">Open</button>
        <button class="fbtn" data-f="hit">Resolved · hit</button>
        <button class="fbtn" data-f="miss">Resolved · miss</button>
        <button class="fbtn" data-f="invalid">Invalidated</button>
      </div>
      <div class="records barscope" id="records">
        {recs.map(({ c, st, p, date, tier }) => (
          <a class="terminal rec" data-status={st} href={`/ledger/${c.id}`}>
            <div class="thead"><span class="cdot r"></span><span class="cdot y"></span><span class="cdot g"></span>
              <span class="fname">ledger — {c.id}</span>
              <span class="tlive" style={`color:${st === 'open' ? 'var(--term-amb)' : st === 'hit' ? 'var(--term-grn)' : st === 'miss' ? 'var(--term-red)' : 'var(--term-dim)'}`}>{st === 'open' && (<span class="dot"></span>)}<span class={`stt ${st}`}>{label[st]}</span></span>
            </div>
            <div class="tbody"><span class="c"># {date} · {tier} · {c.committed_by}</span>
<span class="k">claim</span>: <span class="s">"{truncate(c.claim, 96)}"</span>
<span class="k">resolves</span>: <span class="s">{c.resolve_by}</span>
<span class="k">falsifier</span>: <span class="r">"{truncate(c.update_test, 72)}"</span>
<div class="tbar"><span class="lab">probability</span><span class="track"><i style={`width:${p}%`}></i></span><span class="pv">{c.confidence?.toFixed(2)}</span></div>{c.status === 'resolved' && !isInvalid(c) && !isWithdrawn(c) && (<span><span class="k">outcome</span>: <span class={outcomeBinary(c) === 0 ? 'r' : 'g'}>{(c.resolution?.outcome || 'resolved').toUpperCase()}</span></span>)}{isInvalid(c) && (<span><span class="k">outcome</span>: <span class="c">VOID · not scored</span></span>)}</div>
          </a>
        ))}
      </div>
    </section>
  </div>

  <script is:inline>
    document.querySelectorAll('.fbtn').forEach((btn) => btn.addEventListener('click', () => {
      const f = btn.dataset.f;
      document.querySelectorAll('.fbtn').forEach((b) => b.classList.remove('on'));
      btn.classList.add('on');
      document.querySelectorAll('.rec').forEach((r) => {
        r.style.display = (f === 'all' || r.dataset.status === f) ? '' : 'none';
      });
    }));
  </script>
</Base>

<style>
  .ledhero{display:grid;grid-template-columns:1.2fr .8fr;gap:0;border-bottom:2px solid var(--ink)}
  .ledhero .copy{padding:42px 44px 44px 0;border-right:1px solid var(--rule)}
  .ledhero .board{padding:30px 0 30px 40px}
  .ledhero h1{font-family:var(--serif);font-size:clamp(40px,6vw,80px);line-height:.96;letter-spacing:-.015em}
  .ledhero h1 em{font-style:italic;color:var(--accent)}
  .ledhero .deck{margin-top:22px;font-size:20px;line-height:1.55;color:var(--ink2);max-width:48ch}
  .ledhero .deck b{color:var(--ink);font-weight:500}
  .board .side-h{font-family:var(--mono);font-size:11px;letter-spacing:.16em;text-transform:uppercase;color:var(--accent);border-bottom:2px solid var(--ink);padding-bottom:10px;margin-bottom:4px;display:flex;justify-content:space-between}
  @media(max-width:880px){.ledhero{grid-template-columns:1fr}.ledhero .copy{border-right:none;padding:0 0 34px}.ledhero .board{padding:0 0 36px;border-top:1px solid var(--rule)}}
  .calib{display:grid;grid-template-columns:1fr 1fr 1fr;gap:0;border:1.5px solid var(--ink);margin:0}
  .calib .cell{padding:24px 24px;border-right:1px solid var(--rule)}
  .calib .cell:last-child{border-right:none}
  .calib .l{font-family:var(--mono);font-size:11px;text-transform:uppercase;letter-spacing:.1em;color:var(--dim);margin-bottom:8px}
  .calib .v{font-family:var(--serif);font-size:38px;line-height:1;color:var(--ink)}
  .calib .v b{color:var(--accent);font-weight:400}
  .calib .note{font-size:14px;color:var(--ink2);margin-top:8px;line-height:1.45}
  @media(max-width:680px){.calib{grid-template-columns:1fr}.calib .cell{border-right:none;border-bottom:1px solid var(--rule)}}
  .filters{display:flex;gap:10px;flex-wrap:wrap;align-items:center;margin-bottom:26px}
  .fbtn{font-family:var(--mono);font-size:11px;text-transform:uppercase;letter-spacing:.08em;padding:8px 14px;border:1.5px solid var(--rule2);color:var(--ink2);cursor:pointer;background:transparent;transition:.14s}
  .fbtn:hover{border-color:var(--ink)}
  .fbtn.on{background:var(--ink);color:var(--paper);border-color:var(--ink)}
  .records{display:grid;grid-template-columns:1fr 1fr;gap:28px}
  .records .terminal{margin-bottom:0;text-decoration:none;display:block}
  .records .tbody{font-size:12.5px;line-height:1.9}
  .stt{display:inline-block;font-size:10px;letter-spacing:.1em;text-transform:uppercase;padding:2px 7px;border:1px solid;border-radius:3px}
  .stt.open{color:var(--term-amb);border-color:var(--term-amb)}
  .stt.hit{color:var(--term-grn);border-color:var(--term-grn)}
  .stt.miss{color:var(--term-red);border-color:var(--term-red)}
  .stt.invalid,.stt.withdrawn{color:var(--term-dim);border-color:var(--term-dim)}
  @media(max-width:820px){.records{grid-template-columns:1fr}}
</style>
