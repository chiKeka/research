---
import Base from '../layouts/Base.astro';
import ScorePanel from '../components/ScorePanel.astro';
import ledger from '../data/ledger.json';
import { classify, pct, truncate, attribution } from '../lib/ledger-stats.mjs';

const claims = ledger.claims ?? [];
const { open, resolved, invalid, withdrawn } = classify(claims);
const source = ledger.source ?? null;
---

<Base
  title="Prediction Ledger"
  description="A public, score-kept record of falsifiable predictions — locked probabilities, immutable, Brier-scored."
>
  <p class="eyebrow">The prediction ledger</p>
  <hr class="accent-rule" />
  <h1 style="font-size:clamp(2rem,4.5vw,2.9rem)">Score, kept in public</h1>
  <p class="lede measure">
    Every claim is registered with a probability that locks the moment it is
    stated, a written test for what would disconfirm it, and a resolve-by date.
    Probabilities are never edited; resolutions are never deleted. When the twin
    and I disagree, both numbers stay on the record and reality settles it.
  </p>

  <div class="stats">
    <div class="stat"><div class="n">{open.length}</div><div class="l">Open</div></div>
    <div class="stat"><div class="n">{resolved.length}</div><div class="l">Resolved</div></div>
    <div class="stat"><div class="n">{invalid.length}</div><div class="l">Invalidated</div></div>
    <div class="stat"><div class="n">{withdrawn.length}</div><div class="l">Withdrawn</div></div>
  </div>

  <div class="linkrow">
    <a class="btn" href="https://github.com/chiKeka/ledger">The full record on GitHub →</a>
    <a class="btn" href="https://github.com/chiKeka/ledger/commits/main/ledger.json">Verify every change</a>
    <a class="btn" href="/methodology">How scoring works →</a>
  </div>
  <p class="small muted">
    Invalidated and withdrawn claims stay visible forever but are excluded from
    the Brier score and calibration — the record does not keep wins it did not
    earn. Last updated {ledger.updated}.{source && (
      <>
        {' '}Rendered from <a href={source.url}>chiKeka/ledger@{source.commit_short}</a>.
      </>
    )}
  </p>

  <ScorePanel claims={claims} />

  <h2>Open claims</h2>
  <table class="ledger-table">
    <thead>
      <tr><th>Claim</th><th>Conf.</th><th>By</th><th>Resolve by</th></tr>
    </thead>
    <tbody>
      {open.map((c) => (
        <tr>
          <td><a class="claim-link" href={`/ledger/${c.id}`}>{truncate(c.claim, 180)}</a></td>
          <td class="conf">{pct(c)}</td>
          <td><span class={`tag ${attribution(c) === 'bruno' ? 'bruno' : ''}`}>{attribution(c)}</span></td>
          <td class="small muted">{c.resolve_by}</td>
        </tr>
      ))}
    </tbody>
  </table>

  {resolved.length > 0 && (
    <>
      <h2>Resolved</h2>
      <table class="ledger-table">
        <thead>
          <tr><th>Claim</th><th>Conf.</th><th>By</th><th>Outcome</th></tr>
        </thead>
        <tbody>
          {resolved.map((c) => (
            <tr>
              <td><a class="claim-link" href={`/ledger/${c.id}`}>{truncate(c.claim, 180)}</a></td>
              <td class="conf">{pct(c)}</td>
              <td><span class={`tag ${attribution(c) === 'bruno' ? 'bruno' : ''}`}>{attribution(c)}</span></td>
              <td class="small muted">{c.resolution?.outcome ?? 'resolved'}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </>
  )}

  {invalid.length > 0 && (
    <>
      <h2>Invalidated</h2>
      <p class="small muted measure">
        Registered, then disqualified — most often because the outcome pre-dated
        registration. Kept on the record in full; never scored.
      </p>
      <ul class="list">
        {invalid.map((c) => (
          <li>
            <h3 style="margin:0 0 .3rem"><a class="claim-link" href={`/ledger/${c.id}`}>{c.claim}</a></h3>
            <p class="small muted" style="margin:0">
              <span class="tag warn">invalidated</span> {pct(c)} · {attribution(c)}
              {c.validity?.date && <> · {c.validity.date.slice(0, 10)}</>}
            </p>
            {c.validity?.reason && <p class="muted" style="margin:.35rem 0 0">{c.validity.reason}</p>}
          </li>
        ))}
      </ul>
    </>
  )}

  {withdrawn.length > 0 && (
    <>
      <h2>Withdrawn</h2>
      <ul class="list">
        {withdrawn.map((c) => (
          <li>
            <h3 style="margin:0 0 .3rem"><a class="claim-link" href={`/ledger/${c.id}`}>{c.claim}</a></h3>
            <p class="small muted" style="margin:0"><span class="tag warn">withdrawn</span> {pct(c)} · {attribution(c)}</p>
            {typeof c.withdrawal === 'object' && c.withdrawal?.reason && (
              <p class="muted" style="margin:.35rem 0 0">{c.withdrawal.reason}</p>
            )}
          </li>
        ))}
      </ul>
    </>
  )}

  <hr />
  <p class="small muted measure">
    This is a styled view of the same data published, machine-readable, at
    <a href="https://github.com/chiKeka/ledger">github.com/chiKeka/ledger</a>. The
    site never shows anything the ledger renderer did not produce.
  </p>
</Base>

<style>
  .claim-link { color: var(--ink); text-decoration: none; border-bottom: 1px solid var(--line); }
  .claim-link:hover { color: var(--accent); border-color: var(--accent); }
</style>
