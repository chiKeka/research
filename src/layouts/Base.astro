---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogType?: string;
  ogImage?: string;
  publishedTime?: string;
  modifiedTime?: string;
  jsonLd?: object | object[];
  tagline?: string;
}
const {
  title,
  description,
  ogType = 'website',
  ogImage = '/og.png',
  publishedTime,
  modifiedTime,
  jsonLd,
  tagline = '● Built in the open · predictions locked & scored',
} = Astro.props;

const siteName = 'Bruno Chikeka — Research';
const pageTitle = title ? `${title} · ${siteName}` : siteName;
const desc =
  description ??
  'Systems-oriented technology research: AI infrastructure, institutions, and a public, score-kept prediction ledger.';

const site = Astro.site ?? new URL('https://research-azure-omega.vercel.app');
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const canonical = new URL(path, site).href;
const ogImageUrl = new URL(ogImage, site).href;

const baseGraph = [
  { '@type': 'WebSite', '@id': `${site.origin}/#website`, url: site.origin, name: siteName, description: desc },
  {
    '@type': 'Person',
    '@id': `${site.origin}/#person`,
    name: 'Bruno Chikeka',
    url: site.origin,
    image: `${site.origin}/portrait.jpg`,
    jobTitle: 'Systems-oriented technologist',
    description:
      'Bruno Chikeka is a systems-oriented technologist researching AI infrastructure, agentic systems, and governance, with a public, score-kept prediction ledger.',
    knowsAbout: [
      'AI infrastructure',
      'Agentic systems',
      'AI governance',
      'Sovereign compute',
      'Forecasting',
      'Public epistemics',
    ],
    worksFor: { '@type': 'Organization', name: 'Afrigent' },
    sameAs: [
      'https://x.com/Chikeka',
      'https://github.com/chiKeka',
      'https://www.linkedin.com/in/bruno-chikeka',
    ],
  },
];
const extra = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
const structuredData = { '@context': 'https://schema.org', '@graph': [...baseGraph, ...extra] };
const jsonLdString = JSON.stringify(structuredData).replace(/</g, '\\u003c');

const nav = [
  { href: '/', label: 'Home' },
  { href: '/research', label: 'Research' },
  { href: '/writing', label: 'Writing' },
  { href: '/ledger', label: 'Ledger' },
  { href: '/frameworks', label: 'Frameworks' },
  { href: '/projects', label: 'Projects' },
  { href: '/about', label: 'About' },
];
const isCurrent = (href: string) =>
  href === '/' ? path === '/' : path === href || path.startsWith(href + '/');
const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={desc} />
    <link rel="canonical" href={canonical} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;1,6..72,400&family=Space+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />

    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1600" />
    <meta property="og:image:height" content="840" />
    {ogType === 'article' && publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {ogType === 'article' && modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@Chikeka" />
    <meta name="twitter:creator" content="@Chikeka" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={desc} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="alternate" type="application/rss+xml" title="Bruno Chikeka — Writing" href="/rss.xml" />
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'><text y='25' font-size='26'>🜔</text></svg>" />
    <script type="application/ld+json" set:html={jsonLdString} is:inline />
  </head>
  <body>
    <header class="site">
      <div class="wrap">
        <div class="topbar">
          <span>Vol. III — Systems Desk</span>
          <span class="e">{tagline}</span>
          <span>Africa × Alberta</span>
        </div>
        <div class="mast">
          <a class="name" href="/">Bruno Chikeka <b>· Research</b></a>
          <div class="vol">A systems<br />research practice<br />est. 2024</div>
        </div>
      </div>
      <nav class="sections">
        {nav.map((n) => (
          <a href={n.href} class={isCurrent(n.href) ? 'active' : undefined} aria-current={isCurrent(n.href) ? 'page' : undefined}>{n.label}</a>
        ))}
      </nav>
    </header>

    <slot />

    <footer class="site">
      <div class="wrap foot">
        <span>© {year} Bruno Chikeka · built in the open</span>
        <div class="footlinks">
          <a href="https://github.com/chiKeka/research">Source</a>
          <a href="https://github.com/chiKeka/ledger">Ledger repo</a>
          <a href="/rss.xml">RSS</a>
          <a href="https://x.com/Chikeka">@Chikeka</a>
        </div>
      </div>
    </footer>
  </body>
</html>
